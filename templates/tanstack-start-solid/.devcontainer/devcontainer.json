// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "TanStack App (Node.js + Deno)",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  // =============================================================================
  // VOLUME MOUNTS - Performance Optimization Strategy
  // =============================================================================
  // We use a named Docker volume for node_modules instead of bind-mounting from
  // the host. This provides significant performance benefits:
  //
  // 1. FAST I/O: Docker volumes have native filesystem performance, while bind
  //    mounts (especially on macOS/Windows) add significant overhead for the
  //    thousands of small files in node_modules.
  //
  // 2. ISOLATION: Changes to node_modules in the container don't sync back to
  //    host, preventing file-watching issues and conflicts between different
  //    Node/OS versions.
  //
  // TRADE-OFF: node_modules persists in a Docker volume, so it survives container
  // rebuilds but gets deleted if you remove the volume. This is actually desirable
  // since it ensures clean installs when needed.
  // =============================================================================
  "mounts": [
    "source=tanstack-app-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
      "moby": false
    },
    // mise (formerly rtx) manages tool versions (Node, Python, aube, etc.)
    // from mise.toml. This ensures everyone uses the same runtime versions.
    "ghcr.io/devcontainers-extra/features/mise:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/git-lfs:1": {
      "autoPull": true,
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "hverlin.mise-vscode",
        "VoidZero.vite-plus-extension-pack"
      ],
      "settings": {
        "mise.binPath": "/usr/local/bin/mise",

        "chat.autopilot.enabled": true,
        "chat.tools.terminal.sandbox.enabled": true,
        "chat.tools.terminal.sandbox.macFileSystem": {
          "allowWrite": [
            "${workspaceFolder}/.agents",
            "${workspaceFolder}/src",
            "${workspaceFolder}/docs",
            "${workspaceFolder}/content"
          ],
          "denyWrite": [
            "${workspaceFolder}",
            "${workspaceFolder}/.env",
            "${workspaceFolder}/.env.local",
            "${workspaceFolder}/.gitattributes",
            "${workspaceFolder}/.git",
            "${workspaceFolder}/.github",
            "${workspaceFolder}/.devcontainer",
            "${workspaceFolder}/.vscode"
          ]
        },
        "chat.tools.terminal.sandbox.linuxFileSystem": {
          "allowWrite": [
            "${workspaceFolder}/.agents",
            "${workspaceFolder}/src",
            "${workspaceFolder}/docs",
            "${workspaceFolder}/content"
          ],
          "denyWrite": [
            "${workspaceFolder}",
            "${workspaceFolder}/.env",
            "${workspaceFolder}/.env.local",
            "${workspaceFolder}/.gitattributes",
            "${workspaceFolder}/.git",
            "${workspaceFolder}/.github",
            "${workspaceFolder}/.devcontainer",
            "${workspaceFolder}/.vscode"
          ]
        },
        "chat.tools.edits.autoApprove": {
          "**/*": false,
          "**/.agents/research/**": true,
          "**/src/**": true,
          "**/docs/**": true,
          "**/content/**": true,
          "**/.vscode/**": false,
          "**/.git/**": false,
          "**/.devcontainer/**": false,
          "**/.github/**": false,
          "**/{package.json,server.xml,build.rs,web.config,.gitattributes,.env,.env.local,.npmrc,pyproject.toml,aube-workspace.yaml}": false,
          "**/*.{code-workspace,csproj,fsproj,vbproj,vcxproj,proj,targets,props,pem,crt}": false,
          "**/*.lock": false,
          "**/*-lock.{yaml,json}": false,
          "**/Dockerfile*": false,
          "**/docker-compose*.{yml,yaml}": false,
          "**/mise.toml": false,
          "**/pyproject.toml": false,
          "**/requirements*.txt": false,
          "**/uv.lock": false,
          "**/aube-workspace.yaml": false,
          "**/pnpm-workspace.yaml": false,
          "**/tsconfig*.json": false,
          "**/deno.json*": false
        },
        "chat.tools.terminal.sandbox.network": {
          "allowedDomains": [
            "12factor.net",
            "a11yproject.com",
            "apple.com",
            "arc42.org",
            "arxiv.org",
            "astro.build",
            "aws.amazon.com",
            "azure.microsoft.com",
            "basecamp.com",
            "bazel.build",
            "bcg.com",
            "bun.sh",
            "c4model.com",
            "cloud.google.com",
            "cmake.org",
            "code.visualstudio.com",
            "conventionalcommits.org",
            "crates.io",
            "csrc.nist.gov",
            "dataart.team",
            "databricks.com",
            "deno.com",
            "deno.land",
            "designsystemsrepo.com",
            "dev.to",
            "devdocs.io",
            "developer.apple.com",
            "developer.mozilla.org",
            "docker.com",
            "docs.docker.com",
            "docs.github.com",
            "docs.pydantic.dev",
            "docs.rs",
            "ecma-international.org",
            "esbuild.github.io",
            "eslint.org",
            "esm.sh",
            "fastapi.tiangolo.com",
            "git-scm.com",
            "github.com",
            "gnu.org",
            "go.dev",
            "google.github.io",
            "gradle.org",
            "grafana.com",
            "hbr.org",
            "helm.sh",
            "highscalability.com",
            "k6.io",
            "huggingface.co",
            "ieee.org",
            "ietf.org",
            "iso.org",
            "istio.io",
            "json-schema.org",
            "jsr.io",
            "keepachangelog.com",
            "khronos.org",
            "kotlinlang.org",
            "kubernetes.io",
            "lakefs.io",
            "landskill.com",
            "lawsofux.com",
            "letsencrypt.org",
            "man7.org",
            "martinfowler.com",
            "marvinh.dev",
            "material.io",
            "maven.apache.org",
            "medium.com",
            "microservices.io",
            "mitre.org",
            "mlops.community",
            "nngroup.com",
