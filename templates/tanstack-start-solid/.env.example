# Public values must use VITE_ and are bundled into the client by Vite.
VITE_SITE_ORIGIN=http://localhost:3000

# Optional IPX remote allowlist. Leave empty to serve only local public/ images.
# IPX_HTTP_DOMAINS=images.unsplash.com,cdn.example.com

# Private runtime values should be read only in server functions or server routes.
# DATABASE_URL=
